                defense: '🛡️ Verteidigung', lives: '❤️ Leben', firerate: '⚡ Feuerrate',
                damage: '💥 Schaden', x2money: '💰 x2 Geld',
                buy: 'KAUFEN', level: 'Lv', cost: 'Preis', back: 'ZURÜCK',
                paused: 'PAUSE', resume: 'WEITER', quit: 'BEENDEN',
                gameover: 'NICHT ÜBERLEBT', tryagain: 'NOCHMAL',
                mainmenu: 'HAUPTMENÜ', wasted: 'TOT'
            },
            'es': {
                play: 'JUGAR', settings: 'AJUSTES', credits: 'CRÉDITOS',
                hp: 'SALUD', wave: 'OLEADA', kills: 'BAJAS', shop: 'TIENDA',
                defense: '🛡️ Defensa', lives: '❤️ Vidas', firerate: '⚡ Cadencia',
                damage: '💥 Daño', x2money: '💰 x2 Dinero',
                buy: 'COMPRAR', level: 'Nivel', cost: 'Coste', back: 'VOLVER',
                paused: 'PAUSA', resume: 'CONTINUAR', quit: 'SALIR',
                gameover: 'HAS MUERTO', tryagain: 'REINTENTAR',
                mainmenu: 'MENÚ', wasted: 'ELIMINADO'
            }
        };

        const UPGRADES = [
            { id: 'defense', nameKey: 'defense', cost: 20, effect: 0.05 },
            { id: 'lives', nameKey: 'lives', cost: 15, effect: 20 },
            { id: 'firerate', nameKey: 'firerate', cost: 30, effect: 40 },
            { id: 'damage', nameKey: 'damage', cost: 30, effect: 5 },
            { id: 'x2money', nameKey: 'x2money', cost: 150, effect: 2 }
        ];

        class Player {
            constructor() {
                this.x = WORLD_SIZE / 2;
                this.y = WORLD_SIZE / 2;
                this.radius = 20;
                this.speed = 4.5;
                this.hp = 100;
                this.maxHp = 100;
                this.money = 0;
                this.damage = 10;
                this.fireRate = 600;
                this.lastShot = 0;
                this.defense = 0;
                this.moneyMult = 1;
                this.levels = { defense: 0, lives: 0, firerate: 0, damage: 0, x2money: 0 };
                this.angle = 0;
                this.frame = 0;
            }

            update() {
                let dx = 0;
                let dy = 0;
                
                if (keys['KeyW'] || keys['ArrowUp']) dy -= 1;
                if (keys['KeyS'] || keys['ArrowDown']) dy += 1;
                if (keys['KeyA'] || keys['ArrowLeft']) dx -= 1;
                if (keys['KeyD'] || keys['ArrowRight']) dx += 1;

                if (joystickActive) {
                    dx = joystickVector.x;
                    dy = joystickVector.y;
                }

                if (dx !== 0 || dy !== 0) {
                    const mag = Math.sqrt(dx*dx + dy*dy);
                    this.x += (dx/mag) * this.speed;
                    this.y += (dy/mag) * this.speed;
                    this.frame += 0.15;
                    this.angle = Math.atan2(dy, dx);
                }

                this.x = Math.max(this.radius, Math.min(WORLD_SIZE - this.radius, this.x));
                this.y = Math.max(this.radius, Math.min(WORLD_SIZE - this.radius, this.y));

                const now = Date.now();
                if (now - this.lastShot > this.fireRate) {
                    const target = this.getNearestZombie();
                    if (target) {
                        this.shoot(target);
                        this.lastShot = now;
                    }
                }
            }

            getNearestZombie() {
                let nearest = null;
                let minDist = 600;
                zombies.forEach(z => {
                    const d = Math.hypot(z.x - this.x, z.y - this.y);
                    if (d < minDist) {
                        minDist = d;
                        nearest = z;
                    }
                });
                return nearest;
            }

            shoot(target) {
                const angle = Math.atan2(target.y - this.y, target.x - this.x);
                bullets.push(new Bullet(this.x, this.y, angle, this.damage));
            }

            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.fillStyle = 'rgba(0,0,0,0.4)';
                ctx.beginPath();
                ctx.ellipse(0, 15, 15, 8, 0, 0, Math.PI*2);
                ctx.fill();
                ctx.rotate(this.angle);
                ctx.font = '32px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                const wobble = Math.sin(this.frame) * 3;
                ctx.fillText('🤠', wobble, 0);
                ctx.restore();
            }
        }

        class Zombie {
            constructor(wave) {
                const angle = Math.random() * Math.PI * 2;
                const spawnDist = 700;
                this.x = player.x + Math.cos(angle) * spawnDist;
                this.y = player.y + Math.sin(angle) * spawnDist;
                this.radius = 18;
                this.hp = 15 + (wave * 12);
                this.maxHp = this.hp;
                this.speed = 1.2 + Math.random() * 1.5 + (wave * 0.1);
                this.damage = 10;
                this.frame = Math.random() * 10;
            }

            update() {
                const angle = Math.atan2(player.y - this.y, player.x - this.x);
                this.x += Math.cos(angle) * this.speed;
                this.y += Math.sin(angle) * this.speed;
                this.frame += 0.1;
                if (Math.hypot(this.x - player.x, this.y - player.y) < this.radius + player.radius) {
                    const dmg = this.damage * (1 - player.defense);
                    player.hp -= dmg;
                    spawnParticles(player.x, player.y, '#ff0000', 5);
                    this.x -= Math.cos(angle) * 40;
                    this.y -= Math.sin(angle) * 40;
                    if (player.hp <= 0) endGame();
                }
            }

            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.fillStyle = '#222';
                ctx.fillRect(-15, -28, 30, 4);
                ctx.fillStyle = '#f00';
                ctx.fillRect(-15, -28, (this.hp / this.maxHp) * 30, 4);
                const wobble = Math.sin(this.frame) * 2;
                ctx.font = '28px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('🧟', wobble, 0);
                ctx.restore();
            }
        }

        class Bullet {
            constructor(x, y, angle, damage) {
                this.x = x;
                this.y = y;
                this.vx = Math.cos(angle) * 15;
                this.vy = Math.sin(angle) * 15;
                this.damage = damage;
                this.radius = 4;
                this.life = 100;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.life--;
                for (let i = zombies.length - 1; i >= 0; i--) {
                    const z = zombies[i];
                    if (Math.hypot(this.x - z.x, this.y - z.y) < z.radius + this.radius) {
                        z.hp -= this.damage;
                        spawnParticles(this.x, this.y, '#ffcc00', 3);
                        this.life = 0;
                        if (z.hp <= 0) {
                            const reward = Math.floor((10 + Math.random() * 5) * player.moneyMult);
                            player.money += reward;
                            kills++;
                            spawnParticles(z.x, z.y, '#44ff44', 8, `+$${reward}`);
                            zombies.splice(i, 1);
                        }
                        break;
                    }
                }
            }

            draw() {
                ctx.fillStyle = '#fff';
                ctx.shadowBlur = 10;
                ctx.shadowColor = '#fff';
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI*2);
                ctx.fill();
                ctx.shadowBlur = 0;
            }
        }

        class Particle {
            constructor(x, y, color, text = null) {
                this.x = x;
                this.y = y;
                this.vx = (Math.random() - 0.5) * 4;
                this.vy = (Math.random() - 0.5) * 4;
                this.life = 1.0;
                this.color = color;
                this.text = text;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.life -= 0.02;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.life;
                if (this.text) {
                    ctx.fillStyle = this.color;
                    ctx.font = 'bold 18px Arial';
                    ctx.textAlign = 'center';
                    ctx.fillText(this.text, this.x, this.y);
                } else {
                    ctx.fillStyle = this.color;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, 2.5, 0, Math.PI*2);
                    ctx.fill();
                }
                ctx.restore();
            }
        }

        function spawnParticles(x, y, color, count, text = null) {
            if (text) {
                particles.push(new Particle(x, y, color, text));
            } else {
                for (let i = 0; i < count; i++) {
                    particles.push(new Particle(x, y, color));
                }
            }
        }

        function init() {
            window.addEventListener('keydown', e => {
                keys[e.code] = true;
                if (e.code === 'KeyE') toggleShop();
                if (e.code === 'Escape') togglePause();
            });
            window.addEventListener('keyup', e => keys[e.code] = false);
            document.body.addEventListener('dblclick', e => e.preventDefault());

            const joyContainer = document.getElementById('joystick-container');
            joyContainer.addEventListener('touchstart', e => {
                if (state !== 'PLAYING') return;
                const touch = e.touches[0];
                joystickActive = true;
                joystickStart = { x: touch.clientX, y: touch.clientY };
                joystickBase.style.display = 'block';
                joystickBase.style.left = touch.clientX + 'px';
                joystickBase.style.top = touch.clientY + 'px';
                joystickKnob.style.transform = `translate(0, 0)`;
            }, { passive: true });

            window.addEventListener('touchmove', e => {
                if (!joystickActive) return;
                const touch = e.touches[0];
                const dx = touch.clientX - joystickStart.x;
                const dy = touch.clientY - joystickStart.y;
                const dist = Math.hypot(dx, dy);
                const maxDist = 40;
                const angle = Math.atan2(dy, dx);
                const moveDist = Math.min(dist, maxDist);
                joystickKnob.style.transform = `translate(${Math.cos(angle) * moveDist}px, ${Math.sin(angle) * moveDist}px)`;
                joystickVector.x = Math.cos(angle) * (moveDist / maxDist);
                joystickVector.y = Math.sin(angle) * (moveDist / maxDist);
            }, { passive: true });

            window.addEventListener('touchend', () => {
                joystickActive = false;
                joystickBase.style.display = 'none';
                joystickVector = { x: 0, y: 0 };
            });

            const savedLang = localStorage.getItem(APP_STORAGE_KEY + '_lang');
            setLanguage(savedLang || 'en-us');
            resize();
            window.addEventListener('resize', resize);
            requestAnimationFrame(gameLoop);
        }

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function setLanguage(lang) {
            language = lang;
            localStorage.setItem(APP_STORAGE_KEY + '_lang', lang);
            const t = i18n[lang];
            document.getElementById('btn-play').textContent = t.play;
            document.getElementById('btn-settings').textContent = t.settings;
            document.getElementById('btn-credits').textContent = t.credits;
            document.getElementById('label-hp').textContent = t.hp;
            document.getElementById('label-wave').textContent = t.wave;
            document.getElementById('label-settings').textContent = t.settings;
            document.getElementById('label-credits').textContent = t.credits;
            document.getElementById('label-shop').textContent = t.shop;
            document.getElementById('label-paused').textContent = t.paused;
            document.getElementById('label-gameover-sub').textContent = t.gameover;
            document.getElementById('label-final-wave').textContent = t.wave;
            document.getElementById('label-final-kills').textContent = t.kills;
            document.getElementById('label-wasted').textContent = t.wasted;
            if (isShopOpen) renderShop();
        }

        function showPanel(id) {
            document.querySelectorAll('.overlay').forEach(el => el.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            if (id === 'main-menu') {
                state = 'MENU';
                document.getElementById('shop-btn-trigger').classList.add('hidden');
            }
        }

        function startGame() {
            player = new Player();
            zombies = [];
            bullets = [];
            particles = [];
            wave = 1;
            kills = 0;
            spawnTimer = 0;
            isPaused = false;
            isShopOpen = false;
            state = 'PLAYING';
            document.querySelectorAll('.overlay').forEach(el => el.classList.add('hidden'));
            document.getElementById('hud').classList.remove('hidden');
            document.getElementById('shop-btn-trigger').classList.remove('hidden');
        }

        function togglePause() {
            if (state !== 'PLAYING' && state !== 'PAUSED') return;
            isPaused = !isPaused;
            state = isPaused ? 'PAUSED' : 'PLAYING';
            document.getElementById('pause-menu').classList.toggle('hidden', !isPaused);
        }

        function toggleShop() {
            if (state !== 'PLAYING' && state !== 'SHOP') return;
            isShopOpen = !isShopOpen;
            state = isShopOpen ? 'SHOP' : 'PLAYING';
            document.getElementById('shop-overlay').classList.toggle('hidden', !isShopOpen);
            if (isShopOpen) renderShop();
        }

        function renderShop() {
            const container = document.getElementById('shop-items-container');
            const t = i18n[language];
            document.getElementById('shop-money').textContent = player.money;
            container.innerHTML = UPGRADES.map(upg => {
                const canAfford = player.money >= upg.cost;
                const isMaxed = upg.id === 'x2money' && player.levels[upg.id] >= 1;
                return `
                    <div class="shop-item">
                        <div class="shop-item-info">
                            <div>${t[upg.nameKey] || upg.id}</div>
                            <div>${t.level} ${player.levels[upg.id]}</div>
                        </div>
                        <div style="color: var(--accent)">${isMaxed ? 'MAX' : '$' + upg.cost}</div>
                        <button ${canAfford && !isMaxed ? '' : 'disabled'} onclick="buyUpgrade('${upg.id}')">${isMaxed ? '---' : t.buy}</button>
                    </div>
                `;
            }).join('');
        }

        function buyUpgrade(id) {
            const upg = UPGRADES.find(u => u.id === id);
            if (player.money >= upg.cost) {
                player.money -= upg.cost;
                player.levels[id]++;
                
                if (id === 'defense') player.defense = Math.min(0.8, player.defense + upg.effect);
                if (id === 'lives') { player.maxHp += upg.effect; player.hp = player.maxHp; }
                if (id === 'firerate') player.fireRate = Math.max(100, player.fireRate - upg.effect);
                if (id === 'damage') player.damage += upg.effect;
                if (id === 'x2money') player.moneyMult = 2;

                // Increase cost for next purchase (except one-time x2money)
                if (id !== 'x2money') {
                    upg.cost = Math.floor(upg.cost * 1.6);
                }

                renderShop();
                updateHUD();
            }
        }

        function updateHUD() {
            if (!player) return;
            document.getElementById('hud-money').textContent = player.money;
            document.getElementById('hud-wave').textContent = wave;
            document.getElementById('hud-kills').textContent = kills;
            const hpPercent = (player.hp / player.maxHp) * 100;
            document.getElementById('health-fill').style.width = `${Math.max(0, hpPercent)}%`;
        }

        function endGame() {
            state = 'GAMEOVER';
            document.getElementById('hud').classList.add('hidden');
            document.getElementById('shop-btn-trigger').classList.add('hidden');
            document.getElementById('final-wave').textContent = wave;
            document.getElementById('final-kills').textContent = kills;
            showPanel('game-over');
        }

        function gameLoop(time) {
            const dt = time - lastTime;
            lastTime = time;
            if (state === 'PLAYING') update();
            draw();
            requestAnimationFrame(gameLoop);
        }

        function update() {
            if (!player) return;
            player.update();
            spawnTimer--;
            if (spawnTimer <= 0) {
                const maxZombies = 6 + (wave * 4);
                if (zombies.length < maxZombies) {
                    zombies.push(new Zombie(wave));
                    spawnTimer = Math.max(8, 50 - (wave * 2));
                }
            }
            if (kills >= wave * 15) {
                wave++;
                spawnParticles(player.x, player.y, '#fff', 20, `WAVE ${wave}`);
            }
            for (let i = zombies.length - 1; i >= 0; i--) zombies[i].update();
            for (let i = bullets.length - 1; i >= 0; i--) {
                bullets[i].update();
                if (bullets[i].life <= 0) bullets.splice(i, 1);
            }
            for (let i = particles.length - 1; i >= 0; i--) {
                particles[i].update();
                if (particles[i].life <= 0) particles.splice(i, 1);
            }
            updateHUD();
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (player && (state === 'PLAYING' || state === 'PAUSED' || state === 'SHOP' || state === 'GAMEOVER')) {
                ctx.save();
                ctx.translate(canvas.width / 2 - player.x, canvas.height / 2 - player.y);
                
                // Floor
                ctx.fillStyle = '#0a0a0a';
                ctx.fillRect(0, 0, WORLD_SIZE, WORLD_SIZE);
                
                // Grid
                ctx.strokeStyle = '#1a1a1a';
                ctx.lineWidth = 1;
                for(let x = 0; x <= WORLD_SIZE; x += 60) {
                    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, WORLD_SIZE); ctx.stroke();
                }
                for(let y = 0; y <= WORLD_SIZE; y += 60) {
                    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(WORLD_SIZE, y); ctx.stroke();
                }
                
                // Border
                ctx.strokeStyle = '#ff4d4d';
                ctx.lineWidth = 10;
                ctx.strokeRect(0, 0, WORLD_SIZE, WORLD_SIZE);
                
                particles.forEach(p => p.draw());
                bullets.forEach(b => b.draw());
                zombies.forEach(z => z.draw());
                player.draw();
                ctx.restore();
                
                // Vignette
                const grad = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 100, canvas.width/2, canvas.height/2, Math.max(canvas.width, canvas.height) * 0.6);
                grad.addColorStop(0, 'rgba(0,0,0,0)');
                grad.addColorStop(1, 'rgba(0,0,0,0.85)');
                ctx.fillStyle = grad;
                ctx.fillRect(0, 0, canvas.width, canvas.height);
            } else if (state === 'MENU') {
                ctx.fillStyle = '#050505';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
            }
        }

        init();
    </script>
</body>
</html>