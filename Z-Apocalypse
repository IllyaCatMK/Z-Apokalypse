                    <span id="label-wave">WAVE</span>: <span id="hud-wave">1</span>
                </div>
                <div class="hud-item">
                    💀 <span id="hud-kills">0</span>
                </div>
            </div>
        </div>

        <button id="shop-btn-trigger" class="hidden" onclick="toggleShop()">🛒</button>

        <div id="main-menu" class="overlay">
            <div class="title-container">
                <h1>Z-SURVIVOR</h1>
                <p style="letter-spacing: 5px; color: #888; font-size: 0.8rem;">APOCALYPSE PROTOCOL</p>
            </div>
            <div class="menu-buttons">
                <button id="btn-play" onclick="startGame()">PLAY</button>
                <button id="btn-settings" onclick="showPanel('settings-panel')">SETTINGS</button>
                <button id="btn-credits" onclick="showPanel('credits-panel')">CREDITS</button>
            </div>
        </div>

        <div id="settings-panel" class="overlay hidden">
            <div style="background: var(--panel); padding: 2rem; border-radius: 20px; border: 1px solid var(--primary); width: min(90%, 400px);">
                <h2 id="label-settings" style="margin-top:0; color: var(--primary);">SETTINGS</h2>
                <div class="lang-grid">
                    <button onclick="setLanguage('ru')">🇷🇺 RU</button>
                    <button onclick="setLanguage('en-us')">🇺🇸 EN</button>
                    <button onclick="setLanguage('jp')">🇯🇵 JP</button>
                    <button onclick="setLanguage('de')">🇩🇪 DE</button>
                    <button onclick="setLanguage('es')">🇪🇸 ES</button>
                    <button onclick="setLanguage('en-uk')">🇬🇧 UK</button>
                </div>
                <button style="margin-top: 2rem; width: 100%;" onclick="showPanel('main-menu')">BACK</button>
            </div>
        </div>

        <div id="credits-panel" class="overlay hidden">
            <div style="background: var(--panel); padding: 2rem; border-radius: 20px; border: 1px solid var(--primary); max-width: 400px; text-align: center;">
                <h2 id="label-credits" style="margin-top:0; color: var(--primary);">CREDITS</h2>
                <p>Created by AI Expert Generator</p>
                <p>Visuals: Canvas & Unicode</p>
                <p>Engine: Custom JS</p>
                <button style="margin-top: 1rem; width: 100%;" onclick="showPanel('main-menu')">BACK</button>
            </div>
        </div>

        <div id="shop-overlay" class="overlay hidden">
            <div id="shop-panel">
                <div class="shop-header">
                    <h2 id="label-shop" style="font-size: 1.1rem; margin: 0;">SHOP</h2>
                    <div style="font-size: 1.1rem; color: var(--accent);">💰 <span id="shop-money">0</span></div>
                </div>
                <div id="shop-items-container"></div>
                <button style="margin-top: 1rem; width: 100%; padding: 0.8rem;" onclick="toggleShop()">RESUME</button>
            </div>
        </div>

        <div id="game-over" class="overlay hidden">
            <h1 id="label-wasted" style="color: var(--primary); margin-bottom: 0;">WASTED</h1>
            <p id="label-gameover-sub" style="margin-bottom: 2rem; color: #888;">YOU DID NOT SURVIVE THE NIGHT</p>
            <div class="stat-row"><span id="label-final-wave">WAVE</span>: <span id="final-wave">0</span></div>
            <div class="stat-row"><span id="label-final-kills">KILLS</span>: <span id="final-kills">0</span></div>
            <div class="menu-buttons" style="margin-top: 2rem;">
                <button onclick="startGame()">TRY AGAIN</button>
                <button onclick="showPanel('main-menu')">MAIN MENU</button>
            </div>
        </div>

        <div id="pause-menu" class="overlay hidden">
            <h1 id="label-paused">PAUSED</h1>
            <div class="menu-buttons">
                <button onclick="togglePause()">RESUME</button>
                <button onclick="showPanel('main-menu')">QUIT</button>
            </div>
        </div>
    </div>

    <script>
        const APP_STORAGE_KEY = 'Z_SURVIVOR_DATA_V4';
        const WORLD_SIZE = 1200;
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');

        let state = 'MENU';
        let lastTime = 0;
        let keys = {};
        let language = 'en-us';

        let player = null;
        let zombies = [];
        let bullets = [];
        let particles = [];
        let wave = 1;
        let kills = 0;
        let spawnTimer = 0;
        let isPaused = false;
        let isShopOpen = false;

        let joystickActive = false;
        let joystickStart = { x: 0, y: 0 };
        let joystickVector = { x: 0, y: 0 };
        const joystickBase = document.getElementById('joystick-base');
        const joystickKnob = document.getElementById('joystick-knob');

        const i18n = {
