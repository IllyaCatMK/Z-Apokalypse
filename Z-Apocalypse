        </div>

        <div id="hud" class="hidden">
            <div class="hud-left">
                <div class="hud-item">
                    <span id="label-hp">HEALTH</span>
                    <div id="health-bar-container"><div id="health-fill"></div></div>
                </div>
                <div class="hud-item">
                    💰 <span id="hud-money">0</span>
