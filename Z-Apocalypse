<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Z-SURVIVOR: APOCALYPSE</title>
    <style>
        :root {
            --primary: #ff4d4d;
            --secondary: #2c3e50;
            --accent: #f1c40f;
            --bg: #0a0a0a;
            --text: #e0e0e0;
            --panel: rgba(20, 20, 20, 0.98);
            --safe-top: env(safe-area-inset-top, 36px);
            --safe-bottom: env(safe-area-inset-bottom, 20px);
            --safe-left: env(safe-area-inset-left, 16px);
            --safe-right: env(safe-area-inset-right, 16px);
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
            -webkit-user-select: none;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Helvetica', 'Arial', sans-serif;
            overflow: hidden;
            touch-action: none;
            -webkit-touch-callout: none;
        }

        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            background: #050505;
            overflow: hidden;
        }

        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            transition: opacity 0.3s ease;
        }

        .hidden {
            display: none !important;
            opacity: 0;
            pointer-events: none;
        }

        #main-menu {
            background: radial-gradient(circle, rgba(40,0,0,0.6) 0%, rgba(0,0,0,0.95) 100%);
        }

        .title-container {
            text-align: center;
            margin-bottom: 2rem;
            animation: titleGlow 2s infinite alternate;
        }

        @keyframes titleGlow {
            from { text-shadow: 0 0 10px var(--primary); }
            to { text-shadow: 0 0 30px var(--primary), 0 0 40px #800; }
        }

        h1 {
            font-size: clamp(2.5rem, 10vw, 5rem);
            margin: 0;
            color: var(--primary);
            letter-spacing: 8px;
            text-transform: uppercase;
        }

        .menu-buttons {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            width: min(80vw, 300px);
        }

        button {
            padding: 1.2rem 2rem;
            font-size: 1.1rem;
            background: rgba(0,0,0,0.7);
            border: 2px solid var(--primary);
            color: var(--primary);
            cursor: pointer;
            transition: all 0.2s;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 2px;
            border-radius: 8px;
        }

        button:active {
            transform: scale(0.95);
            background: var(--primary);
            color: white;
        }

        button:disabled {
            border-color: #444;
            color: #444;
            cursor: not-allowed;
            opacity: 0.5;
        }

        #hud {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: var(--safe-top) var(--safe-right) 0 var(--safe-left);
            display: flex;
            justify-content: space-between;
            pointer-events: none;
            z-index: 50;
        }

        .hud-item {
            background: rgba(0,0,0,0.7);
            padding: 0.8rem 1.2rem;
            border-radius: 12px;
            border-left: 4px solid var(--primary);
            font-weight: bold;
            font-size: 1rem;
            backdrop-filter: blur(10px);
            margin-bottom: 10px;
        }

        #health-bar-container {
            width: 120px;
            height: 10px;
            background: #222;
            border: 1px solid #444;
            margin-top: 5px;
            border-radius: 5px;
            overflow: hidden;
        }

        #health-fill {
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, #ff4d4d, #ff0000);
            transition: width 0.3s ease;
        }

        #shop-panel {
            background: var(--panel);
            padding: 1.25rem;
            border: 2px solid var(--primary);
            border-radius: 16px;
            width: min(85vw, 380px);
            max-height: 70vh;
            overflow-y: auto;
            box-shadow: 0 0 40px rgba(255, 77, 77, 0.4);
            touch-action: pan-y !important; 
            -webkit-overflow-scrolling: touch;
        }

        .shop-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            border-bottom: 1px solid #444;
            padding-bottom: 0.5rem;
            position: sticky;
            top: 0;
            background: var(--panel);
            z-index: 10;
        }

        .shop-item {
            display: grid;
            grid-template-columns: 1fr auto auto;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
            padding: 0.75rem;
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
        }

        .shop-item-info div:first-child {
            font-weight: bold;
            color: var(--accent);
            font-size: 0.9rem;
        }

        .shop-item-info div:last-child {
            font-size: 0.75rem;
            opacity: 0.7;
        }

        .shop-item button {
            padding: 0.5rem 0.8rem;
            font-size: 0.8rem;
        }

        .lang-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 1rem;
        }

        #joystick-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 10;
            pointer-events: auto;
        }

        .joystick-visual {
            position: absolute;
            width: 100px;
            height: 100px;
            background: rgba(255,255,255,0.1);
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 50%;
            display: none;
            pointer-events: none;
            transform: translate(-50%, -50%);
            backdrop-filter: blur(5px);
        }

        .joystick-knob {
            width: 40px;
            height: 40px;
            background: var(--primary);
            border-radius: 50%;
            position: absolute;
            top: 30px;
            left: 30px;
            box-shadow: 0 0 15px var(--primary);
        }

        #shop-btn-trigger {
            position: absolute;
            bottom: calc(var(--safe-bottom) + 20px);
            right: calc(var(--safe-right) + 20px);
            z-index: 60;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--accent);
            color: black;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            border: none;
            pointer-events: auto;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <canvas id="gameCanvas"></canvas>

        <div id="joystick-container">
            <div class="joystick-visual" id="joystick-base">
                <div class="joystick-knob" id="joystick-knob"></div>
